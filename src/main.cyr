# owl — main entry point
# Stdlib auto-included via cyrius.cyml

include "lib/vyakarana.cyr"
include "src/lang.cyr"
include "src/theme.cyr"
include "src/pager.cyr"
include "src/vcs.cyr"
include "src/config.cyr"

# Keep OWL_VERSION in sync with the VERSION file.
# A M8 CI check will enforce equality; for now, manual.
var OWL_VERSION = "owl 1.1.8";

var BUFSIZE = 65536;

# M3b — cap on file size for token-highlighted rendering. Larger files
# fall back to plain streaming (decorations still render; token-level
# color does not). Sized conservatively against the bump allocator:
# the highlight path keeps the full file, the tokenbuf, and an
# ANSI-inflated output buffer resident concurrently, so the working
# set is ~4× the file size. Raising this needs a freeing allocator
# or a streaming tokenizer (vyakarana 2.x / M5 per its ROADMAP).
var HIGHLIGHT_MAX = 131072;

# Exit codes per design spec §9
var EXIT_OK       = 0;
var EXIT_PARTIAL  = 1;
var EXIT_USAGE    = 2;
var EXIT_ALL_FAIL = 4;

# ── Mode + theme state (resolved after flag parse) ─────────────────────
var g_decorated = 0;
var g_want_color = 0;

# Flag state set during arg parse. -1 = unset/auto, 0 = off, 1 = on.
var g_flag_numbers  = 0 - 1;
var g_flag_plain    = 0;
var g_flag_color    = 0 - 1;
var g_flag_lang     = 0;           # pointer to --language value, 0 if unset
var g_active_theme  = 0;           # theme index (default 0 = dark)
var g_active_lang   = "plain";     # detected per-file; surfaced for M3b

# M5 — non-printables + whitespace
var g_flag_show_all = 0;           # -A
var g_flag_tabs     = 4;           # --tabs=N; 0 = preserve literal \t
# --wrap is parsed for spec compatibility but doesn't yet insert breaks.
# "never" matches the current behavior (terminal handles visual wrap);
# "character" mode needs a TIOCGWINSZ col count — deferred to M8.
var g_flag_wrap     = 0;           # 0 auto, 1 never, 2 character
var g_flag_verbose  = 0;           # -v / --verbose; expands --version output
# --strip-ansi=auto|always|never. 0=auto (current default: strip in
# decorated/colored), 1=always (strip even in -p plain mode), 2=never
# (alias of -r, passthrough). `-r` and `--raw-control-chars` remain the
# canonical opt-out; this flag mirrors `less -R` naming for muscle memory.
var g_flag_strip_ansi = 0;
# --hex / -x: force xxd-style hex dump for any file (binary or text).
# Auto-fallback also fires when a binary file is detected via NUL-byte
# scan, replacing the pre-1.1.3 skip-notice with a useful dump.
var g_flag_hex = 0;
# --diff: filter rendered output to lines with VCS markers (ADD/MOD).
# Forces VCS computation regardless of decoration state. Composes with
# --line-range and --color (just gates emission via _in_range).
var g_flag_diff = 0;
# --line-range=A:B (1-indexed, inclusive). 0 = unset; either or both
# may stay open. Render paths gate byte emission on _in_range();
# once g_line_no passes the end, g_render_done short-circuits the
# read loop in render_fd_loop.
var g_line_range_start = 0;
var g_line_range_end   = 0;
var g_render_done      = 0;
# --wrap=character: terminal column width and current column. cols=0
# means "unset / wrap disabled"; resolved in resolve_mode after the
# TTY check. col tracks bytes emitted on the current visible row and
# resets at every emitted '\n' (file-origin or wrap-inserted).
var g_wrap_cols = 0;
var g_wrap_col  = 0;

# 1.1.7 — bat-style header frame. _term_cols result cached per file so
# top/middle/bottom rules render at a consistent width even if the
# window resizes mid-file. g_header_open pairs emit_header with a
# matching emit_footer in the main loop after each rendered file.
var g_term_cols   = 0;
var g_header_open = 0;

# 1.1.8 — wrap-continuation needs to know the in-flight token color
# so the gutter break can reset, draw the continuation prefix in
# lineno color, and restore the prior token color. render_highlighted_buf
# writes this on every color transition; render_chunk leaves it -1.
var g_render_active_color = 0 - 1;

# Audit FINDING-001: file-origin terminal escapes are stripped from
# the byte stream in decorated/colored output. `-r` / `--raw-control-chars`
# restores the old cat-like passthrough for users who are viewing
# trusted ANSI-colored output (e.g. a captured test log). `-p` already
# does this via a separate code path; `-A` renders ESC visibly as `^[`
# so the classifier is bypassed in that mode too.
var g_flag_raw_controls = 0;

# Escape-stripping state machine — persists across chunks, resets per
# file in render_reset.
#   0  normal
#   1  saw ESC, awaiting introducer
#   2  in CSI, scanning for final byte (0x40–0x7E)
#   3  in OSC/DCS/APC/PM/SOS string, scanning for ST/BEL
#   4  in string body, just saw ESC (next byte might be `\` → ST)
var g_esc_state = 0;

# Streaming render state, reset per input.
var g_line_no       = 1;
var g_at_line_start = 1;

# ── TTY detection ──────────────────────────────────────────────────────

# TTY detection via ioctl(fd, TCGETS). Succeeds only on terminals —
# unlike fstat+S_IFCHR, which also matches /dev/null, /dev/zero, and
# any other character device. (That's the bug that let `owl ... > /dev/null`
# spawn the pager: /dev/null is a char device but not a terminal.)
# TCGETS = 0x5401 on Linux. termios is ~44 bytes; oversizing is free.
fn is_tty(fd) {
    var tbuf[128];
    var r = syscall(SYS_IOCTL, fd, 0x5401, &tbuf);
    if (r < 0) { return 0; }
    return 1;
}

# Terminal column count via TIOCGWINSZ on stdout. Returns 0 if not a
# TTY (callers default to 80). winsize = { ws_row, ws_col, ws_xpixel,
# ws_ypixel } as four u16; ws_col is at offset 2.
fn _term_cols() {
    var ws[8];
    var r = syscall(SYS_IOCTL, STDOUT, 0x5413, &ws);
    if (r < 0) { return 0; }
    var lo = load8(&ws + 2);
    var hi = load8(&ws + 3);
    return hi * 256 + lo;
}

# ── Mode resolution ────────────────────────────────────────────────────

fn resolve_mode() {
    g_decorated = is_tty(STDOUT);

    # NO_COLOR — standard convention, any non-empty value disables color
    # unless --color=always already forced it on.
    var nc = getenv("NO_COLOR");
    if (nc != 0) {
        if (load8(nc) != 0) {
            if (g_flag_color != 1) { g_flag_color = 0; }
        }
    }

    # -p overrides everything: no decorations, no color.
    if (g_flag_plain == 1) {
        g_decorated = 0;
        g_want_color = 0;
        return 0;
    }

    # -n lifts decorated on (so numbers render even when piped).
    if (g_flag_numbers == 1) { g_decorated = 1; }

    # Color resolution (independent of decorated — numbers can be on
    # without color when piped, per --color=never).
    if (g_flag_color == 1) { g_want_color = 1; }
    else { if (g_flag_color == 0) { g_want_color = 0; }
           else { g_want_color = is_tty(STDOUT); } }

    # --wrap resolution. 1.1.8: auto (default) wraps when the
    # decorated frame is rendering so content stays inside the bottom
    # rule. character forces wrap regardless of decoration (still
    # useful for scripted fixed-width capture). never is the explicit
    # overflow escape hatch. Plain mode (-p) and piped output without
    # decorations still bypass wrap entirely (cat parity).
    g_wrap_cols = 0;
    var wrap_on = 0;
    if (g_flag_wrap == 2)                          { wrap_on = 1; }
    if (g_flag_wrap == 0) { if (g_decorated == 1) { wrap_on = 1; } }
    if (wrap_on == 1) {
        var c = _term_cols();
        if (c == 0) { c = 80; }
        # Reserve gutter prefix (lineno + space + optional VCS cell +
        # divider + space). Conservative — uses VCS-on width even when
        # VCS will turn out off, so wrapped content may stop 2 cols
        # before the right rule when VCS is inactive. Acceptable.
        if (resolved_show_numbers() == 1) {
            if (c > 13) { c = c - 11; }
        }
        g_wrap_cols = c;
    }

    return 0;
}

fn resolved_show_numbers() {
    if (g_flag_plain == 1) { return 0; }
    if (g_flag_numbers == 1) { return 1; }
    if (g_flag_numbers == 0) { return 0; }
    if (g_decorated == 1) { return 1; }
    return 0;
}

fn resolved_show_header() {
    if (g_flag_plain == 1) { return 0; }
    if (g_decorated == 1) { return 1; }
    return 0;
}

# ── Decoration rendering ───────────────────────────────────────────────

# 1.1.7 — bat-style three-rule header frame.
#
# Layout when VCS markers are inactive (gutter prefix is 9 cols):
#   "───────┬──────────────────────…\n"
#   "       │ File: <path> (<lang>)\n"
#   "───────┼──────────────────────…\n"
#   "     1 │ <content>\n"
#   …
#   "───────┴──────────────────────…\n"
#
# When VCS markers are active the gutter prefix grows by 2 cols and
# each junction shifts from col 7 → col 9 to track the xe2x94x82
# position. Rules span the full terminal width (TIOCGWINSZ on stdout,
# 80-col fallback when not a TTY — header path itself is gated TTY-only
# via resolved_show_header, so the fallback only kicks in for the rare
# decorated-but-no-winsize case).

fn _gutter_divider_col() {
    if (vcs_enabled() == 1) { return 9; }
    return 7;
}

fn _emit_dashes(n: i64) {
    var i: i64 = 0;
    while (i < n) {
        syscall(1, 1, "─", 3);
        i = i + 1;
    }
    return 0;
}

# Emit one horizontal rule with the given junction glyph at the
# divider column. junction is a 3-byte UTF-8 string ("┬" / "┼" / "┴").
fn _emit_rule(junction) {
    var div_col = _gutter_divider_col();
    var cols    = g_term_cols;
    if (cols <= 0)          { cols = 80; }
    if (cols < div_col + 2) { cols = div_col + 2; }
    if (g_want_color == 1) { ansi_fg(theme_lineno_color(g_active_theme)); }
    _emit_dashes(div_col);
    syscall(1, 1, junction, 3);
    _emit_dashes(cols - div_col - 1);
    if (g_want_color == 1) { ansi_reset(); }
    syscall(1, 1, "\n", 1);
    return 0;
}

fn emit_header(path) {
    var c = _term_cols();
    if (c <= 0) { c = 80; }
    g_term_cols = c;

    _emit_rule("┬");

    # Header line: blank gutter (no lineno), divider, then "File: …".
    var div_col = _gutter_divider_col();
    if (g_want_color == 1) { ansi_fg(theme_lineno_color(g_active_theme)); }
    var pad = 0;
    while (pad < div_col) {
        syscall(1, 1, " ", 1);
        pad = pad + 1;
    }
    syscall(1, 1, "│ ", 4);
    if (g_want_color == 1) { ansi_reset(); }

    if (g_want_color == 1) { ansi_fg(theme_header_color(g_active_theme)); }
    syscall(1, 1, "File: ", 6);
    syscall(1, 1, path, strlen(path));
    if (streq(g_active_lang, "plain") == 0) {
        syscall(1, 1, " (", 2);
        syscall(1, 1, g_active_lang, strlen(g_active_lang));
        syscall(1, 1, ")", 1);
    }
    if (g_want_color == 1) { ansi_reset(); }
    syscall(1, 1, "\n", 1);

    _emit_rule("┼");

    g_header_open = 1;
    return 0;
}

# Pair for emit_header. Called from main() after each per-file render
# returns so every code path that opened a header (hex, binary auto,
# highlighted, plain stream) gets a matching bottom rule. No-op when
# the header never opened (plain mode, piped without -n, etc.).
fn emit_footer() {
    if (g_header_open == 0) { return 0; }
    _emit_rule("┴");
    g_header_open = 0;
    return 0;
}

# Gutter layout:
#   "     1 " (6-char right-aligned lineno + space)
#   " "       (change-marker cell: '+'/'~'/'-' or ' ', its own color)
#   " │ "     (divider + space, lineno color)
#
# The change-marker cell is only emitted when vcs_enabled() == 1 so
# the gutter stays narrow when --style=no-changes / --no-color or
# when we're outside a repo.
fn emit_lineno(ln: i64) {
    if (_in_range() == 0) { return 0; }
    var pbuf[8];
    var n = ln;
    var pi: i64 = 5;
    if (n == 0) { store8(&pbuf + pi, 48); pi = pi - 1; }
    while (n > 0) {
        store8(&pbuf + pi, 48 + n % 10);
        pi = pi - 1;
        n = n / 10;
    }
    while (pi >= 0) {
        store8(&pbuf + pi, 32);
        pi = pi - 1;
    }
    store8(&pbuf + 6, 32);

    if (g_want_color == 1) { ansi_fg(theme_lineno_color(g_active_theme)); }
    syscall(1, 1, &pbuf, 7);
    if (g_want_color == 1) { ansi_reset(); }

    if (vcs_enabled() == 1) {
        var mk = vcs_mark_for_line(ln);
        if (mk == VCS_MARK_NONE) {
            syscall(1, 1, "  ", 2);
        } else {
            var mcolor = theme_change_color(g_active_theme, mk);
            if (g_want_color == 1) {
                if (mcolor != 0 - 1) { ansi_fg(mcolor); }
            }
            if (mk == VCS_MARK_ADD) { syscall(1, 1, "+", 1); }
            if (mk == VCS_MARK_MOD) { syscall(1, 1, "~", 1); }
            if (mk == VCS_MARK_DEL) { syscall(1, 1, "-", 1); }
            if (g_want_color == 1) {
                if (mcolor != 0 - 1) { ansi_reset(); }
            }
            syscall(1, 1, " ", 1);
        }
    }

    var dbuf[4];
    store8(&dbuf + 0, 0xE2);
    store8(&dbuf + 1, 0x94);
    store8(&dbuf + 2, 0x82);
    store8(&dbuf + 3, 32);
    if (g_want_color == 1) { ansi_fg(theme_lineno_color(g_active_theme)); }
    syscall(1, 1, &dbuf, 4);
    if (g_want_color == 1) { ansi_reset(); }
    return 0;
}

# ── Streaming ──────────────────────────────────────────────────────────

# Write up to n bytes from s to stderr, replacing every C0 control
# byte (< 0x20) and DEL (0x7F) with '?'. UTF-8 bytes (>= 0x80) pass
# through so non-ASCII paths stay legible. Audit FINDING-002 — a path
# containing raw ESC would otherwise inject ANSI into whatever reads
# our stderr (log capture, CI output, etc.).
fn eprint_sanitized(s, n) {
    var i = 0;
    while (i < n) {
        var c = load8(s + i);
        if (c < 0x20) {
            eprint("?", 1);
        } else {
            if (c == 0x7F) {
                eprint("?", 1);
            } else {
                eprint(s + i, 1);
            }
        }
        i = i + 1;
    }
    return 0;
}

fn report_error(path, reason) {
    eprint("owl: ", 5);
    eprint_sanitized(path, strlen(path));
    eprint(": ", 2);
    eprint(reason, strlen(reason));
    eprint("\n", 1);
    return 0;
}

# ── Grammar resolution (1.1.2) ─────────────────────────────────────────
# vyakarana's bootstrap loads grammars via the literal relative path
# "grammars/<lang>.cyml" (lib/vyakarana.cyr:1774). That breaks for any
# invocation where the cwd doesn't happen to contain a grammars/
# subdirectory — silently, because grammar_load returns 0 and the
# registry just stays empty, so has_grammar(lang) reports false and
# render_path skips the highlight branch entirely. The user sees plain
# bytes with no error.
#
# Fix: owl resolves grammars/ via /proc/self/exe (binary location)
# before vyakarana's lazy bootstrap fires, pre-loads every grammar
# with an absolute path, and sets _grammars_bootstrapped = 1 so
# vyakarana's relative-path fallback never runs. Tries:
#   1. <exe-dir>/grammars/                       (installed-adjacent)
#   2. <exe-dir>/../grammars/                    (dev: build/owl + ./grammars/)
#   3. cwd-relative via vyakarana's legacy path  (resolved-by 0 on failure)
# Probe is grammars/cyrius.cyml — every owl build has it.

var g_grammars_dir          = 0;   # NUL-term abs path of grammars/, or 0
var g_grammars_dir_resolved = 0;   # cache flag: don't re-resolve

# 1.1.3 — user grammar overlay. Loaded BEFORE bundled in the bootstrap
# so vyakarana's registry_find_by_name (first-match) returns the user
# version when names collide. New language names need a lang.cyr table
# update; the override-only scope here lets a user patch a single
# bundled grammar without that.
var g_user_grammars_dir          = 0;
var g_user_grammars_dir_resolved = 0;

fn _grammar_dir_has_cyrius(dir) {
    # Build "<dir>cyrius.cyml" in a probe buffer, file_open it.
    var dlen = strlen(dir);
    if (dlen + 12 >= 512) { return 0; }
    var probe[512];
    var k = 0;
    while (k < dlen) { store8(&probe + k, load8(dir + k)); k = k + 1; }
    var name = "cyrius.cyml";
    var nlen = strlen(name);
    var j = 0;
    while (j < nlen) { store8(&probe + dlen + j, load8(name + j)); j = j + 1; }
    store8(&probe + dlen + nlen, 0);
    var fd = file_open(&probe, O_RDONLY, 0);
    if (fd < 0) { return 0; }
    file_close(fd);
    return 1;
}

# Build "<base>grammars/" into out (alloc'd). Returns out.
fn _join_grammars(base, base_len) {
    var suffix = "grammars/";
    var slen = strlen(suffix);
    var total = base_len + slen + 1;
    var out = alloc(total);
    var k = 0;
    while (k < base_len) { store8(out + k, load8(base + k)); k = k + 1; }
    var j = 0;
    while (j < slen) { store8(out + base_len + j, load8(suffix + j)); j = j + 1; }
    store8(out + base_len + slen, 0);
    return out;
}

fn _resolve_grammars_dir() {
    if (g_grammars_dir_resolved == 1) { return g_grammars_dir; }
    g_grammars_dir_resolved = 1;

    # readlink /proc/self/exe → absolute binary path. SYS_readlink = 89
    # on Linux x86_64. Returns negative on failure (no /proc, etc.).
    var link[512];
    var n = syscall(89, "/proc/self/exe", &link, 511);
    if (n <= 0) { g_grammars_dir = 0; return 0; }
    store8(&link + n, 0);

    # Find last "/" — everything before it (inclusive) is the exe dir.
    var slash = n;
    while (slash > 0) {
        if (load8(&link + slash - 1) == 47) { break; }
        slash = slash - 1;
    }

    # Candidate 1: <exe-dir>/grammars/
    var c1 = _join_grammars(&link, slash);
    if (_grammar_dir_has_cyrius(c1) == 1) {
        g_grammars_dir = c1;
        return c1;
    }

    # Candidate 2: <exe-dir>/../grammars/  (covers build/owl + ./grammars/)
    # Strip one trailing path component from the exe dir to get parent.
    if (slash > 1) {
        var parent_end = slash - 1;     # skip trailing "/"
        while (parent_end > 0) {
            if (load8(&link + parent_end - 1) == 47) { break; }
            parent_end = parent_end - 1;
        }
        var c2 = _join_grammars(&link, parent_end);
        if (_grammar_dir_has_cyrius(c2) == 1) {
            g_grammars_dir = c2;
            return c2;
        }
    }

    # No exe-relative dir found. Leave g_grammars_dir = 0; caller will
    # let vyakarana fall back to cwd-relative load. That fallback works
    # only when cwd has grammars/ — same as pre-1.1.2 behavior.
    g_grammars_dir = 0;
    return 0;
}

# Build "<base>/owl/grammars/" given an absolute-prefix base. base_len
# is the byte length of base (no trailing slash assumed).
fn _join_user_grammars(base, base_len) {
    var suffix = "/owl/grammars/";
    var slen = strlen(suffix);
    var total = base_len + slen + 1;
    var out = alloc(total);
    var k = 0;
    while (k < base_len) { store8(out + k, load8(base + k)); k = k + 1; }
    var j = 0;
    while (j < slen) { store8(out + base_len + j, load8(suffix + j)); j = j + 1; }
    store8(out + base_len + slen, 0);
    return out;
}

# Resolve the user grammars dir. Tries $XDG_CONFIG_HOME first, falls
# back to $HOME/.config. Returns 0 if neither exists or neither dir
# contains any usable grammar (no need to error — user grammars are
# strictly opt-in).
fn _resolve_user_grammars_dir() {
    if (g_user_grammars_dir_resolved == 1) { return g_user_grammars_dir; }
    g_user_grammars_dir_resolved = 1;

    var xdg = getenv("XDG_CONFIG_HOME");
    if (xdg != 0) {
        if (load8(xdg) != 0) {
            var c = _join_user_grammars(xdg, strlen(xdg));
            # Replace "/owl/grammars/" with "owl/grammars/" — the
            # XDG var is already absolute, no leading slash needed.
            # _join_user_grammars added one; rewrite to skip it.
            # Easier path: build directly.
            var xlen = strlen(xdg);
            var suffix = "/owl/grammars/";
            var slen = strlen(suffix);
            var dir = alloc(xlen + slen + 1);
            var k = 0;
            while (k < xlen) { store8(dir + k, load8(xdg + k)); k = k + 1; }
            var j = 0;
            while (j < slen) { store8(dir + xlen + j, load8(suffix + j)); j = j + 1; }
            store8(dir + xlen + slen, 0);
            g_user_grammars_dir = dir;
            return dir;
        }
    }

    var home = getenv("HOME");
    if (home != 0) {
        if (load8(home) != 0) {
            var hlen = strlen(home);
            var suffix = "/.config/owl/grammars/";
            var slen = strlen(suffix);
            var dir = alloc(hlen + slen + 1);
            var k = 0;
            while (k < hlen) { store8(dir + k, load8(home + k)); k = k + 1; }
            var j = 0;
            while (j < slen) { store8(dir + hlen + j, load8(suffix + j)); j = j + 1; }
            store8(dir + hlen + slen, 0);
            g_user_grammars_dir = dir;
            return dir;
        }
    }

    g_user_grammars_dir = 0;
    return 0;
}

# Load one grammar by name (e.g. "shell.cyml") from the resolved dir.
# Caller pre-allocates path_buf to avoid alloc-per-language churn.
fn _owl_load_grammar(dir, path_buf, name) {
    var dlen = strlen(dir);
    var nlen = strlen(name);
    var k = 0;
    while (k < dlen) { store8(path_buf + k, load8(dir + k)); k = k + 1; }
    var j = 0;
    while (j < nlen) { store8(path_buf + dlen + j, load8(name + j)); j = j + 1; }
    store8(path_buf + dlen + nlen, 0);
    var g = grammar_load(path_buf);
    if (g != 0) { registry_add(g); }
    return 0;
}

# Owl-side bootstrap. Pre-loads every bundled grammar via an absolute
# path resolved from /proc/self/exe, then sets vyakarana's
# _grammars_bootstrapped flag so its lazy relative-path bootstrap
# doesn't fire and overwrite the registry with failed loads.
# Idempotent. Cheap on the second call.
fn _owl_bootstrap_grammars() {
    if (_grammars_bootstrapped == 1) { return 0; }
    var dir = _resolve_grammars_dir();
    if (dir == 0) { return 0; }   # let vyakarana's relative path try

    registry_init();
    var path = alloc(1024);

    # User overlay first — vyakarana's registry is a vec, find_by_name
    # returns first match, so user grammars win by name when present.
    # Missing files are silently skipped (grammar_load returns 0).
    var udir = _resolve_user_grammars_dir();
    if (udir != 0) {
        _owl_load_grammar(udir, path, "shell.cyml");
        _owl_load_grammar(udir, path, "toml.cyml");
        _owl_load_grammar(udir, path, "json.cyml");
        _owl_load_grammar(udir, path, "cyrius.cyml");
        _owl_load_grammar(udir, path, "rust.cyml");
        _owl_load_grammar(udir, path, "yaml.cyml");
        _owl_load_grammar(udir, path, "markdown.cyml");
        _owl_load_grammar(udir, path, "c.cyml");
        _owl_load_grammar(udir, path, "typescript.cyml");
        _owl_load_grammar(udir, path, "javascript.cyml");
        _owl_load_grammar(udir, path, "python.cyml");
    }

    # Bundled.
    _owl_load_grammar(dir, path, "shell.cyml");
    _owl_load_grammar(dir, path, "toml.cyml");
    _owl_load_grammar(dir, path, "json.cyml");
    _owl_load_grammar(dir, path, "cyrius.cyml");
    _owl_load_grammar(dir, path, "rust.cyml");
    _owl_load_grammar(dir, path, "yaml.cyml");
    _owl_load_grammar(dir, path, "markdown.cyml");
    _owl_load_grammar(dir, path, "c.cyml");
    _owl_load_grammar(dir, path, "typescript.cyml");
    _owl_load_grammar(dir, path, "javascript.cyml");
    _owl_load_grammar(dir, path, "python.cyml");

    _grammars_bootstrapped = 1;
    return 0;
}

# Wrapper around vyakarana's has_grammar that ensures owl's
# absolute-path bootstrap runs first.
fn _owl_has_grammar(lang) {
    _owl_bootstrap_grammars();
    return has_grammar(lang);
}

# ── Hex dump (1.1.3) ───────────────────────────────────────────────────
# xxd-style: "OFFSET  HH HH HH HH HH HH HH HH  HH HH HH HH HH HH HH HH  |ASCII|\n"
# Triggered explicitly via --hex/-x or as auto-fallback when binary
# content is detected (1.1.3 replaces the pre-1.1.3 skip-notice).
# Plain mode (-p) still streams bytes verbatim — cat-parity is sacred.

fn _hex_byte_pair(buf, off, c) {
    var hi = c / 16;
    var lo = c % 16;
    if (hi < 10) { store8(buf + off,     48 + hi); }
    else         { store8(buf + off,     87 + hi); }
    if (lo < 10) { store8(buf + off + 1, 48 + lo); }
    else         { store8(buf + off + 1, 87 + lo); }
    return 0;
}

# Write an 8-digit hex offset into buf starting at off. Big-endian.
fn _hex_offset(buf, off, value) {
    var i = 7;
    var v = value;
    while (i >= 0) {
        var d = v % 16;
        if (d < 10) { store8(buf + off + i, 48 + d); }
        else        { store8(buf + off + i, 87 + d); }
        v = v / 16;
        i = i - 1;
    }
    return 0;
}

# Emit one 16-byte hex line. n may be < 16 for the trailing partial.
fn _hex_emit_line(buf, n, base_offset) {
    var line[80];
    _hex_offset(&line, 0, base_offset);
    store8(&line + 8,  32);
    store8(&line + 9,  32);
    var pos = 10;
    var k = 0;
    while (k < 16) {
        if (k < n) {
            _hex_byte_pair(&line, pos, load8(buf + k));
        } else {
            store8(&line + pos,     32);
            store8(&line + pos + 1, 32);
        }
        pos = pos + 2;
        if (k == 7) {
            store8(&line + pos,     32);
            store8(&line + pos + 1, 32);
            pos = pos + 2;
        } else {
            if (k < 15) {
                store8(&line + pos, 32);
                pos = pos + 1;
            }
        }
        k = k + 1;
    }
    store8(&line + pos,     32);
    store8(&line + pos + 1, 32);
    store8(&line + pos + 2, 124);
    pos = pos + 3;
    var a = 0;
    while (a < n) {
        var c = load8(buf + a);
        if (c >= 32) {
            if (c < 127) { store8(&line + pos, c); }
            else         { store8(&line + pos, 46); }
        } else {
            store8(&line + pos, 46);
        }
        pos = pos + 1;
        a = a + 1;
    }
    store8(&line + pos, 124);
    pos = pos + 1;
    store8(&line + pos, 10);
    pos = pos + 1;
    file_write(STDOUT, &line, pos);
    return 0;
}

# Stream a file as xxd-style hex. first_buf holds bytes already read
# from fd (e.g. by render_path for binary detection). Caller closes fd.
fn _hex_dump_fd(fd, first_buf, first_n) {
    var pending[16];
    var pending_len = 0;
    var off = 0;

    var i = 0;
    while (i < first_n) {
        store8(&pending + pending_len, load8(first_buf + i));
        pending_len = pending_len + 1;
        if (pending_len == 16) {
            _hex_emit_line(&pending, 16, off);
            off = off + 16;
            pending_len = 0;
        }
        i = i + 1;
    }

    var buf = alloc(BUFSIZE);
    var done = 0;
    while (done == 0) {
        var n = file_read(fd, buf, BUFSIZE);
        if (n < 0) { return 0 - 1; }
        if (n == 0) {
            done = 1;
            continue;
        }
        var j = 0;
        while (j < n) {
            store8(&pending + pending_len, load8(buf + j));
            pending_len = pending_len + 1;
            if (pending_len == 16) {
                _hex_emit_line(&pending, 16, off);
                off = off + 16;
                pending_len = 0;
            }
            j = j + 1;
        }
    }
    if (pending_len > 0) {
        _hex_emit_line(&pending, pending_len, off);
    }
    return 0;
}

fn render_reset() {
    g_line_no = 1;
    g_at_line_start = 1;
    g_esc_state = 0;
    g_render_done = 0;
    g_wrap_col = 0;
    return 0;
}

# Is g_line_no inside the user's --line-range window?
fn _in_range() {
    if (g_line_range_start > 0) {
        if (g_line_no < g_line_range_start) { return 0; }
    }
    if (g_line_range_end > 0) {
        if (g_line_no > g_line_range_end) { return 0; }
    }
    if (g_flag_diff == 1) {
        if (vcs_mark_for_line(g_line_no) == VCS_MARK_NONE) { return 0; }
    }
    return 1;
}

# 1.1.8 — wrap line break with continuation gutter. Saves the active
# token color (set by render_highlighted_buf), resets so the gutter
# renders cleanly in lineno color, then restores the token color so
# the next byte continues with its highlighting intact. render_chunk
# leaves g_render_active_color at -1 so the save/restore is a no-op.
fn _emit_wrap_break() {
    var saved = g_render_active_color;
    if (saved != 0 - 1) {
        if (g_want_color == 1) { ansi_reset(); }
    }
    file_write(STDOUT, "\n", 1);
    if (g_want_color == 1) { ansi_fg(theme_lineno_color(g_active_theme)); }
    var div_col = _gutter_divider_col();
    var pad = 0;
    while (pad < div_col) {
        syscall(1, 1, " ", 1);
        pad = pad + 1;
    }
    syscall(1, 1, "│ ", 4);
    if (g_want_color == 1) { ansi_reset(); }
    if (saved != 0 - 1) {
        if (g_want_color == 1) { ansi_fg(saved); }
    }
    return 0;
}

# Range-gated stdout write. Identical to file_write(STDOUT, …) when
# no range is set; one comparison + branch overhead otherwise.
fn _emit(buf, n) {
    if (_in_range() == 0) { return 0; }
    # Fast paths: plain mode (sacred) or wrap inactive. g_wrap_cols is
    # 0 unless resolve_mode turned wrap on (--wrap=character forces it
    # always; 1.1.8 --wrap=auto turns it on whenever the decorated
    # frame is rendering, so wrapped content stays inside the bottom
    # rule).
    if (g_flag_plain == 1) { file_write(STDOUT, buf, n); return 0; }
    if (g_wrap_cols == 0)  { file_write(STDOUT, buf, n); return 0; }

    # Wrap path: byte-by-byte with column tracking. Insert a wrap-\n
    # + continuation gutter before any UTF-8 leading byte that would
    # push past g_wrap_cols. Continuation bytes (0x80..0xBF) don't
    # count as columns, so multi-byte codepoints stay intact across
    # wraps. File-origin \n resets g_wrap_col without a continuation
    # gutter (next line gets its own emit_lineno from the caller).
    var k = 0;
    while (k < n) {
        var c = load8(buf + k);
        if (c == 10) {
            file_write(STDOUT, buf + k, 1);
            g_wrap_col = 0;
        } else {
            var is_cont = 0;
            if (c >= 0x80) {
                if (c < 0xC0) { is_cont = 1; }
            }
            if (is_cont == 0) {
                if (g_wrap_col >= g_wrap_cols) {
                    _emit_wrap_break();
                    g_wrap_col = 0;
                }
                g_wrap_col = g_wrap_col + 1;
            }
            file_write(STDOUT, buf + k, 1);
        }
        k = k + 1;
    }
    return 0;
}

# Is file-origin escape stripping active for the current render?
# Plain mode is cat parity (no stripping), -A renders every control
# visibly (so stripping would double-hide), --raw-control-chars is the
# explicit opt-out. Without color decoration, file bytes aren't
# mingled with owl's own SGR output, so the injection path doesn't
# exist — skip stripping to preserve cat-parity latency.
fn _strip_active() {
    # Plain mode is sacred — byte-identical to cat regardless of any
    # other flag (CLAUDE.md). show-all renders escapes as ^[ glyphs,
    # so stripping would double-hide them.
    if (g_flag_plain == 1)        { return 0; }
    if (g_flag_show_all == 1)     { return 0; }
    # Explicit overrides — these only fire in non-plain mode and so
    # never threaten cat-parity. always wins over -r intentionally:
    # the more recently-named knob takes priority.
    if (g_flag_strip_ansi == 1)   { return 1; }   # --strip-ansi=always
    if (g_flag_strip_ansi == 2)   { return 0; }   # --strip-ansi=never
    if (g_flag_raw_controls == 1) { return 0; }   # -r / --raw-control-chars
    # Auto: strip in decorated/colored output (where owl emits its
    # own SGR), passthrough otherwise.
    if (g_want_color == 0)        { return 0; }
    return 1;
}

# Byte classifier — updates g_esc_state and returns 1 if the byte
# should be emitted to stdout, 0 if it should be dropped as part of a
# file-origin terminal escape sequence. Called only when
# _strip_active() == 1. Strips every ESC-initiated sequence: CSI (ESC
# [ … final), OSC (ESC ] … BEL/ST), DCS/APC/PM/SOS (ESC P/_/^/X …
# ST), and single-char escapes (ESC 7, ESC 8, ESC c, …). Owl's own
# SGR output bypasses this by going through ansi_fg / ansi_reset
# which write to stdout directly — only bytes loaded from the file
# are filtered.
fn _emit_file_byte(c) {
    if (g_esc_state == 0) {
        if (c == 0x1B) { g_esc_state = 1; return 0; }
        return 1;
    }
    if (g_esc_state == 1) {
        # Classify by introducer byte.
        if (c == 0x5B) { g_esc_state = 2; return 0; }   # [ → CSI
        if (c == 0x5D) { g_esc_state = 3; return 0; }   # ] → OSC
        if (c == 0x50) { g_esc_state = 3; return 0; }   # P → DCS
        if (c == 0x5F) { g_esc_state = 3; return 0; }   # _ → APC
        if (c == 0x5E) { g_esc_state = 3; return 0; }   # ^ → PM
        if (c == 0x58) { g_esc_state = 3; return 0; }   # X → SOS
        # Two-byte escape (ESC 7, ESC 8, ESC c, ESC D, ESC M, …).
        g_esc_state = 0;
        return 0;
    }
    if (g_esc_state == 2) {
        # CSI body: params (0x30–0x3F) and intermediates (0x20–0x2F).
        # Final byte is in the 0x40–0x7E range.
        if (c >= 0x40) { if (c <= 0x7E) { g_esc_state = 0; return 0; } }
        return 0;
    }
    if (g_esc_state == 3) {
        # String body: look for BEL, C1 ST (0x9C), or ESC-starting ST.
        if (c == 0x07) { g_esc_state = 0; return 0; }
        if (c == 0x9C) { g_esc_state = 0; return 0; }
        if (c == 0x1B) { g_esc_state = 4; return 0; }
        return 0;
    }
    if (g_esc_state == 4) {
        # Saw ESC inside a string; `\\` (0x5C) terminates, anything
        # else means the ESC was a false alarm and we stay in string.
        if (c == 0x5C) { g_esc_state = 0; return 0; }
        g_esc_state = 3;
        return 0;
    }
    return 1;
}

# Render one buffered chunk through the resolved pipeline:
#   - line-number gutter (from g_flag_numbers / decorated mode)
#   - tab expansion (g_flag_tabs spaces, or literal if 0)
#   - visible non-printables (g_flag_show_all: → for tab, $ for \n,
#     ␍ for CR, ^X / ^? for other control chars)
#
# Three dispatch paths, fastest to slowest:
#   1. No transforms      → bulk file_write of the whole chunk
#   2. Line-numbers only  → chunk-flush on each \n (M2 path)
#   3. Any transform      → byte-by-byte
fn render_chunk(buf, n) {
    # -p is cat-parity: byte-identical passthrough, regardless of -A /
    # --tabs / -n / any other transform flag the user also set. The
    # one exception is --line-range — a user who explicitly asks for
    # lines [A,B] of a file is opting out of full passthrough.
    if (g_flag_plain == 1) {
        if (g_line_range_start == 0) {
            if (g_line_range_end == 0) {
                file_write(STDOUT, buf, n);
                return 0;
            }
        }
        var pi = 0;
        while (pi < n) {
            var pc = load8(buf + pi);
            _emit(buf + pi, 1);
            if (pc == 10) {
                g_line_no = g_line_no + 1;
                if (g_line_range_end > 0) {
                    if (g_line_no > g_line_range_end) {
                        g_render_done = 1;
                        return 0;
                    }
                }
            }
            pi = pi + 1;
        }
        return 0;
    }

    var show_nums = resolved_show_numbers();
    var show_all  = g_flag_show_all;
    var tabs      = g_flag_tabs;
    var strip     = _strip_active();

    var range_active = 0;
    if (g_line_range_start > 0) { range_active = 1; }
    if (g_line_range_end > 0)   { range_active = 1; }

    # Path 1: no transforms at all. Safe for bulk write only when
    # escape-stripping is off — otherwise we'd leak file-origin
    # escapes straight to the terminal. Skipped under --line-range
    # because the bulk spans newlines that would need per-line gating.
    if (strip == 0) {
        if (range_active == 0) {
            if (g_wrap_cols == 0) {
                if (show_nums == 0) {
                    if (show_all == 0) {
                        if (tabs == 0) {
                            file_write(STDOUT, buf, n);
                            return 0;
                        }
                    }
                }
            }
        }

        # Path 2: only line numbers, no byte-level changes. Range
        # filter applies via _emit (each bulk write covers exactly
        # one line ending at \n, so per-line gating is correct).
        if (show_nums == 1) {
            if (show_all == 0) {
                if (tabs == 0) {
                    var start = 0;
                    var j = 0;
                    while (j < n) {
                        if (g_at_line_start == 1) {
                            emit_lineno(g_line_no);
                            g_at_line_start = 0;
                        }
                        if (load8(buf + j) == 10) {
                            _emit(buf + start, j - start + 1);
                            start = j + 1;
                            g_line_no = g_line_no + 1;
                            g_at_line_start = 1;
                            if (g_line_range_end > 0) {
                                if (g_line_no > g_line_range_end) {
                                    g_render_done = 1;
                                    return 0;
                                }
                            }
                        }
                        j = j + 1;
                    }
                    if (start < n) {
                        _emit(buf + start, n - start);
                    }
                    return 0;
                }
            }
        }
    }

    # Path 3: any transform active — byte-by-byte.
    var i = 0;
    while (i < n) {
        if (show_nums == 1) {
            if (g_at_line_start == 1) {
                emit_lineno(g_line_no);
                g_at_line_start = 0;
            }
        }
        var c = load8(buf + i);

        # Strip file-origin terminal escapes (audit FINDING-001).
        # When the classifier swallows a byte, skip all emission AND
        # all state updates so line counters / tab expansion don't
        # fire inside an escape sequence.
        if (strip == 1) {
            if (_emit_file_byte(c) == 0) { i = i + 1; continue; }
        }

        if (c == 10) {
            if (show_all == 1) { _emit("$", 1); }
            _emit("\n", 1);
            g_line_no = g_line_no + 1;
            g_at_line_start = 1;
            if (g_line_range_end > 0) {
                if (g_line_no > g_line_range_end) {
                    g_render_done = 1;
                    return 0;
                }
            }
        } else {
            if (c == 9) {
                if (show_all == 1) {
                    _emit("→", 3);
                    var pad = tabs - 1;
                    if (pad < 0) { pad = 0; }
                    var p = 0;
                    while (p < pad) {
                        _emit(" ", 1);
                        p = p + 1;
                    }
                } else {
                    if (tabs == 0) {
                        _emit("\t", 1);
                    } else {
                        var p = 0;
                        while (p < tabs) {
                            _emit(" ", 1);
                            p = p + 1;
                        }
                    }
                }
            } else {
                if (c == 13) {
                    if (show_all == 1) {
                        _emit("␍", 3);
                    } else {
                        _emit(buf + i, 1);
                    }
                } else {
                    if (show_all == 1) {
                        if (c < 32) {
                            var ctrl[2];
                            store8(&ctrl, 94);
                            store8(&ctrl + 1, c + 64);
                            _emit(&ctrl, 2);
                        } else {
                            if (c == 127) {
                                _emit("^?", 2);
                            } else {
                                _emit(buf + i, 1);
                            }
                        }
                    } else {
                        _emit(buf + i, 1);
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# ── Highlighted render (M3b) ───────────────────────────────────────────
#
# Called when language is detected, vyakarana has a grammar for it, and
# color output is live. `buf` is the full file contents, null-terminated
# at buf[n] (tokenize_source uses strlen internally). Returns 0 on
# success, -1 if tokenization returned no tokenbuf (caller falls back
# to plain passthrough on the same buffer).
#
# Layering: drives the loop byte-by-byte so the line-number gutter, tab
# expansion, and -A non-printable glyphs all still work — M3b adds
# color on top of M2/M5 behaviors, it doesn't replace them. ANSI reset
# is emitted before newlines so line endings don't bleed color into
# the next gutter.
fn render_highlighted_buf(buf, n, lang) {
    var tb = tokenize_source(buf, lang);
    if (tb == 0) { return 0 - 1; }

    var tok_count = tokenbuf_count(tb);
    var tok_i = 0;
    var show_nums = resolved_show_numbers();
    var show_all  = g_flag_show_all;
    var tabs      = g_flag_tabs;
    var theme     = g_active_theme;
    g_render_active_color = 0 - 1;
    var strip     = _strip_active();

    var i = 0;
    while (i < n) {
        # Advance past tokens that ended before this byte.
        while (tok_i < tok_count) {
            var tok_end = tokenbuf_start(tb, tok_i) + tokenbuf_len(tb, tok_i);
            if (tok_end <= i) { tok_i = tok_i + 1; }
            else { break; }
        }
        var kind = 0 - 1;
        if (tok_i < tok_count) {
            if (tokenbuf_start(tb, tok_i) <= i) {
                kind = tokenbuf_kind(tb, tok_i);
            }
        }
        var color = 0 - 1;
        if (kind >= 0) { color = theme_token_color(theme, kind); }

        var c = load8(buf + i);

        # Line-number gutter at line start — clear any active color so
        # the gutter renders in its own lineno color.
        if (show_nums == 1) {
            if (g_at_line_start == 1) {
                if (g_render_active_color != 0 - 1) { ansi_reset(); g_render_active_color = 0 - 1; }
                emit_lineno(g_line_no);
                g_at_line_start = 0;
            }
        }

        # Strip file-origin terminal escapes (audit FINDING-001). Done
        # after the gutter — if the first byte of a new line is the
        # start of an escape, we still want the lineno drawn.
        if (strip == 1) {
            if (_emit_file_byte(c) == 0) { i = i + 1; continue; }
        }

        # Color transitions: reset before \n, otherwise apply this
        # token's color if different from what's active.
        if (c == 10) {
            if (g_render_active_color != 0 - 1) { ansi_reset(); g_render_active_color = 0 - 1; }
        } else {
            if (color != g_render_active_color) {
                if (g_render_active_color != 0 - 1) { ansi_reset(); }
                if (color != 0 - 1) { ansi_fg(color); }
                g_render_active_color = color;
            }
        }

        # Byte-level emission — mirrors render_chunk path 3.
        if (c == 10) {
            if (show_all == 1) { _emit("$", 1); }
            _emit("\n", 1);
            g_line_no = g_line_no + 1;
            g_at_line_start = 1;
            if (g_line_range_end > 0) {
                if (g_line_no > g_line_range_end) {
                    if (g_render_active_color != 0 - 1) { ansi_reset(); }
                    g_render_done = 1;
                    return 0;
                }
            }
        } else {
            if (c == 9) {
                if (show_all == 1) {
                    _emit("→", 3);
                    var pad = tabs - 1;
                    if (pad < 0) { pad = 0; }
                    var p = 0;
                    while (p < pad) {
                        _emit(" ", 1);
                        p = p + 1;
                    }
                } else {
                    if (tabs == 0) {
                        _emit("\t", 1);
                    } else {
                        var p = 0;
                        while (p < tabs) {
                            _emit(" ", 1);
                            p = p + 1;
                        }
                    }
                }
            } else {
                if (c == 13) {
                    if (show_all == 1) {
                        _emit("␍", 3);
                    } else {
                        _emit(buf + i, 1);
                    }
                } else {
                    if (show_all == 1) {
                        if (c < 32) {
                            var ctrl[2];
                            store8(&ctrl, 94);
                            store8(&ctrl + 1, c + 64);
                            _emit(&ctrl, 2);
                        } else {
                            if (c == 127) {
                                _emit("^?", 2);
                            } else {
                                _emit(buf + i, 1);
                            }
                        }
                    } else {
                        _emit(buf + i, 1);
                    }
                }
            }
        }
        i = i + 1;
    }

    if (g_render_active_color != 0 - 1) { ansi_reset(); }
    return 0;
}

fn render_fd_loop(fd) {
    var buf = alloc(BUFSIZE);
    while (1 == 1) {
        if (g_render_done == 1) { return 0; }
        var n = file_read(fd, buf, BUFSIZE);
        if (n < 0) { return 0 - 1; }
        if (n == 0) { return 0; }
        render_chunk(buf, n);
    }
    return 0;
}

fn render_fd(fd, path_for_header) {
    render_reset();
    vcs_reset();

    var lang = "plain";
    if (g_flag_lang != 0) { lang = g_flag_lang; }
    g_active_lang = lang;

    if (resolved_show_header() == 1) { emit_header(path_for_header); }

    # Highlight eligibility — same gate as render_path. Stdin gets the
    # same token color treatment as a file path when --language is set
    # and color is live. Without --language there's no extension or
    # path to detect from, so stdin without a hint stays plain.
    var highlight_ok = 0;
    if (g_want_color == 1) {
        if (streq(lang, "plain") == 0) {
            if (_owl_has_grammar(lang) == 1) { highlight_ok = 1; }
        }
    }

    if (highlight_ok == 0) {
        return render_fd_loop(fd);
    }

    # Slurp up to HIGHLIGHT_MAX. Stdin can be unbounded so we cap and
    # fall back to streaming on overflow, mirroring the render_path
    # branch. One extra byte for tokenize_source's trailing \0.
    var big = alloc(HIGHLIGHT_MAX + 1);
    var total = 0;
    while (total < HIGHLIGHT_MAX) {
        var got = file_read(fd, big + total, HIGHLIGHT_MAX - total);
        if (got < 0) { return 0 - 1; }
        if (got == 0) { break; }
        total = total + got;
    }
    var overflow = 0;
    if (total >= HIGHLIGHT_MAX) {
        var probe[1];
        var pr = file_read(fd, &probe, 1);
        if (pr > 0) { overflow = 1; }
    }
    store8(big + total, 0);

    if (overflow == 0) {
        var hrc = render_highlighted_buf(big, total, lang);
        if (hrc != 0) { render_chunk(big, total); }
        return 0;
    }

    # Overflow — same fallback notice render_path uses, then stream
    # the remainder plainly.
    eprint("owl: ", 5);
    eprint_sanitized(path_for_header, strlen(path_for_header));
    var msg = ": input too large for highlighting (> ";
    eprint(msg, strlen(msg));
    var kb_buf[12];
    var kb = HIGHLIGHT_MAX / 1024;
    var kpi = 11;
    store8(&kb_buf + kpi, 0);
    kpi = kpi - 1;
    if (kb == 0) { store8(&kb_buf + kpi, 48); kpi = kpi - 1; }
    while (kb > 0) {
        store8(&kb_buf + kpi, 48 + kb % 10);
        kpi = kpi - 1;
        kb = kb / 10;
    }
    kpi = kpi + 1;
    eprint(&kb_buf + kpi, 11 - kpi);
    var tail = " KB), rendering without color\n";
    eprint(tail, strlen(tail));

    render_chunk(big, total);
    var rc_big = render_fd_loop(fd);
    if (rc_big < 0) { return 0 - 1; }
    return 0;
}

# Render a file path. Performs extension-based language detection, a
# shebang peek on the first chunk if the extension didn't resolve,
# and honors --language override. M3b splits into two render paths:
#
#   - Highlighted: file fits in HIGHLIGHT_MAX, color is live, and
#     vyakarana has a grammar for the detected language. Whole file
#     is buffered, tokenized once, and rendered with per-token color.
#   - Streaming: everything else (big files, no grammar, no color,
#     plain mode). First chunk renders through render_chunk, rest
#     through render_fd_loop.
fn render_path(path) {
    var fd = file_open(path, O_RDONLY, 0);
    if (fd < 0) {
        report_error(path, "No such file or directory");
        return 0 - 1;
    }

    var lang = detect_language_from_path(path);

    var first_buf = alloc(BUFSIZE);
    var first_n = file_read(fd, first_buf, BUFSIZE);
    if (first_n < 0) {
        file_close(fd);
        report_error(path, "read error");
        return 0 - 1;
    }

    # 1.1.3 — explicit --hex / -x: dump as xxd-style and exit. Wins over
    # everything except -p (cat-parity is sacred). Header still emits
    # under decorated mode so the user sees what they're looking at.
    if (g_flag_hex == 1) {
        if (g_flag_plain == 0) {
            if (resolved_show_header() == 1) { emit_header(path); }
            var hrc = _hex_dump_fd(fd, first_buf, first_n);
            file_close(fd);
            if (hrc < 0) {
                report_error(path, "read error");
                return 0 - 1;
            }
            return 0;
        }
    }

    # Binary file detection — a NUL byte in the first chunk is a strong
    # signal the file isn't meant for terminal display. Skip unless the
    # user explicitly asked for text mode: `-p` (cat parity), `-A`
    # (raw-byte escape view), or `--language=<name>` (asserted type).
    if (g_flag_plain == 0) {
        if (g_flag_show_all == 0) {
            if (g_flag_lang == 0) {
                var nul_hit = 0;
                var j = 0;
                while (j < first_n) {
                    if (load8(first_buf + j) == 0) {
                        nul_hit = 1;
                        j = first_n;
                        continue;
                    }
                    j = j + 1;
                }
                if (nul_hit == 1) {
                    # 1.1.3 — auto-fallback: instead of the pre-1.1.3
                    # "binary file (use -p to dump)" skip-notice, dump
                    # the file as xxd-style hex. Header still emits in
                    # decorated mode so the user sees what they're
                    # looking at.
                    if (resolved_show_header() == 1) { emit_header(path); }
                    var rc = _hex_dump_fd(fd, first_buf, first_n);
                    file_close(fd);
                    if (rc < 0) {
                        report_error(path, "read error");
                        return 0 - 1;
                    }
                    return 0;
                }
            }
        }
    }

    if (streq(lang, "plain") == 1) {
        if (first_n > 0) {
            var sh = detect_language_from_shebang(first_buf, first_n);
            if (sh != 0) { lang = sh; }
        }
    }

    # 1.1.4 — content-based detection as a third-pass fallback. Fires
    # only when extension AND shebang both missed; high-confidence
    # patterns for json/yaml/toml/markdown only (programming languages
    # excluded — false-positive risk).
    if (streq(lang, "plain") == 1) {
        if (first_n > 0) {
            var ct = detect_language_from_content(first_buf, first_n);
            if (ct != 0) { lang = ct; }
        }
    }

    if (g_flag_lang != 0) { lang = g_flag_lang; }

    g_active_lang = lang;

    # Compute VCS markers before any rendering — gutter (M3a) and
    # highlighted-byte loop (M3b) both read through vcs_mark_for_line.
    # Silent no-op when not in a repo, not decorated, or --no-changes.
    vcs_compute_markers(path);

    # Highlighting eligibility. Gated on color (not on decorated) —
    # piped output with --color=always should still color tokens even
    # though the header/gutter stay off. Plain-mode (-p) already forced
    # g_want_color to 0 upstream. `has_grammar` also lazily loads all
    # bundled grammars on first call — cheap after the first file.
    var highlight_ok = 0;
    if (g_want_color == 1) {
        if (streq(lang, "plain") == 0) {
            if (_owl_has_grammar(lang) == 1) { highlight_ok = 1; }
        }
    }

    render_reset();
    if (resolved_show_header() == 1) { emit_header(path); }

    if (highlight_ok == 1) {
        # Buffer the full file (up to HIGHLIGHT_MAX) then tokenize.
        # One extra byte for the trailing \0 that tokenize_source
        # assumes (it uses strlen).
        var big = alloc(HIGHLIGHT_MAX + 1);
        var j = 0;
        while (j < first_n) {
            store8(big + j, load8(first_buf + j));
            j = j + 1;
        }
        var total = first_n;
        while (total < HIGHLIGHT_MAX) {
            var got = file_read(fd, big + total, HIGHLIGHT_MAX - total);
            if (got < 0) {
                file_close(fd);
                report_error(path, "read error");
                return 0 - 1;
            }
            if (got == 0) { break; }
            total = total + got;
        }
        # If we filled the cap, check whether the file is larger.
        var overflow = 0;
        if (total >= HIGHLIGHT_MAX) {
            var probe[1];
            var p = file_read(fd, &probe, 1);
            if (p > 0) { overflow = 1; }
        }
        store8(big + total, 0);

        if (overflow == 0) {
            var hrc = render_highlighted_buf(big, total, lang);
            file_close(fd);
            if (hrc != 0) {
                # Tokenization bailed — emit the buffer plainly so the
                # user still sees the file (decorations already drawn).
                render_chunk(big, total);
            }
            return 0;
        }

        # File exceeds HIGHLIGHT_MAX — flush what we have plainly and
        # stream the remainder. No color, but line numbers / -A / tabs
        # all still apply via render_chunk. Tell the user why color is
        # missing — the gutter stays on, highlighting doesn't, and a
        # silent drop is confusing.
        eprint("owl: ", 5);
        eprint_sanitized(path, strlen(path));
        var msg = ": file too large for highlighting (> ";
        eprint(msg, strlen(msg));
        var kb_buf[12];
        var kb = HIGHLIGHT_MAX / 1024;
        var kpi = 11;
        store8(&kb_buf + kpi, 0);
        kpi = kpi - 1;
        if (kb == 0) { store8(&kb_buf + kpi, 48); kpi = kpi - 1; }
        while (kb > 0) {
            store8(&kb_buf + kpi, 48 + kb % 10);
            kpi = kpi - 1;
            kb = kb / 10;
        }
        kpi = kpi + 1;
        eprint(&kb_buf + kpi, 11 - kpi);
        var tail = " KB), rendering without color\n";
        eprint(tail, strlen(tail));

        render_chunk(big, total);
        var rc_big = render_fd_loop(fd);
        file_close(fd);
        if (rc_big < 0) {
            report_error(path, "read error");
            return 0 - 1;
        }
        return 0;
    }

    render_chunk(first_buf, first_n);
    var rc = render_fd_loop(fd);
    file_close(fd);
    if (rc < 0) {
        report_error(path, "read error");
        return 0 - 1;
    }
    return 0;
}

# ── CLI ────────────────────────────────────────────────────────────────

fn print_version() {
    println(OWL_VERSION);
    if (g_flag_verbose == 1) {
        # Kept in sync with cyrius.cyml [deps.vyakarana].tag and
        # [package].cyrius. Useful for bug reports — "owl 1.1.1
        # vyakarana 1.0.2 cyrius 5.7.12 linux-x86_64" pins the exact
        # toolchain + dep versions a user is running against.
        println("vyakarana 1.0.2");
        println("cyrius 5.7.12");
        println("target linux-x86_64");
    }
    return EXIT_OK;
}

fn print_help() {
    println("owl — a watchful file viewer for AGNOS / Cyrius");
    println("");
    println("Usage:");
    println("  owl [OPTIONS] [FILE...]");
    println("  owl -                  Read from stdin");
    println("  owl a.txt - b.txt      Mix files and stdin");
    println("");
    println("Options:");
    println("  -n, --number           Force line numbers on");
    println("  -N, --no-number        Force line numbers off");
    println("  -p, --plain            Plain output (no decorations)");
    println("  -A, --show-all         Show non-printables: tab as →, EOL as $,");
    println("                         CR as ␍, other controls as ^X");
    println("  -x, --hex              xxd-style hex dump (auto for binary files)");
    println("      --diff             Show only changed lines (uses VCS markers)");
    println("  -r, --raw-control-chars  Pass file-origin terminal escapes through");
    println("                         unchanged (default: strip in decorated mode)");
    println("      --strip-ansi=<when> auto | always | never (less -R style alias of -r)");
    println("      --tabs=<n>         Expand tabs to N spaces (default 4, 0 = literal)");
    println("      --line-range=A:B   Print only lines A..B (1-indexed; A: or :B open-ended)");
    println("                         head -n N idiom: --line-range=:N");
    println("      --wrap=<mode>      auto | never | character — auto wraps to fit the");
    println("                         decorated frame; never lets long lines overflow");
    println("      --color=<when>     auto | always | never");
    println("      --paging=<when>    auto | always | never");
    println("      --style=<mode>     auto | changes | no-changes (gutter VCS markers)");
    println("      --theme=<name>     Syntax theme (dark | light)");
    println("      --list-themes      List bundled themes");
    println("      --language=<name>  Force language (overrides auto-detect)");
    println("      --list-languages   List recognized languages");
    println("  -h, --help             Show this help and exit");
    println("  -v, --verbose          With --version, also print dep + toolchain pins");
    println("  -V, --version          Show version and exit");
    println("");
    println("Config (optional):");
    println("  $OWL_CONFIG, else $XDG_CONFIG_HOME/owl/config.cyml,");
    println("  else ~/.config/owl/config.cyml. Keys: theme, paging,");
    println("  style, tabs, wrap. CLI flags override the config.");
    return EXIT_OK;
}

# Match a long option of the form "--name=VALUE".
# Returns pointer to the VALUE part on match, 0 otherwise.
fn match_eq_flag(arg, name) {
    var nlen = strlen(name);
    if (memeq(arg, name, nlen) == 0) { return 0; }
    if (load8(arg + nlen) != 61) { return 0; }
    return arg + nlen + 1;
}

fn set_color(value) {
    if (streq(value, "auto") == 1)   { g_flag_color = 0 - 1; return 0; }
    if (streq(value, "always") == 1) { g_flag_color = 1;     return 0; }
    if (streq(value, "never") == 1)  { g_flag_color = 0;     return 0; }
    return 1;
}

# Accepts "auto" | "never" | "character". Stored in g_flag_wrap but
# unused by the M5 renderer (the terminal handles visual wrap for all
# three values today). "character" requires TIOCGWINSZ — M8.
fn set_wrap(value) {
    if (streq(value, "auto") == 1)      { g_flag_wrap = 0; return 0; }
    if (streq(value, "never") == 1)     { g_flag_wrap = 1; return 0; }
    if (streq(value, "character") == 1) { g_flag_wrap = 2; return 0; }
    return 1;
}

# --line-range=A:B (1-indexed, inclusive). Either side may be open
# (":B" = 1..B, "A:" = A..end). Single line "A" treated as "A:A".
# Returns 0 on success, 1 on parse error.
fn set_line_range(value) {
    var vlen = strlen(value);
    if (vlen == 0) { return 1; }
    var i = 0;
    var a = 0;
    var has_a = 0;
    while (i < vlen) {
        var c = load8(value + i);
        if (c == 58) { i = i + 1; break; }   # ':' separator
        if (c < 48) { return 1; }
        if (c > 57) { return 1; }
        a = a * 10 + (c - 48);
        has_a = 1;
        i = i + 1;
    }
    var b = 0;
    var has_b = 0;
    while (i < vlen) {
        var c = load8(value + i);
        if (c < 48) { return 1; }
        if (c > 57) { return 1; }
        b = b * 10 + (c - 48);
        has_b = 1;
        i = i + 1;
    }
    # No colon at all: single-line form "A" → range [A,A].
    var saw_colon = 0;
    var k = 0;
    while (k < vlen) {
        if (load8(value + k) == 58) { saw_colon = 1; k = vlen; continue; }
        k = k + 1;
    }
    if (saw_colon == 0) {
        if (has_a == 0) { return 1; }
        g_line_range_start = a;
        g_line_range_end = a;
        return 0;
    }
    if (has_a == 1) { g_line_range_start = a; }
    else            { g_line_range_start = 0; }
    if (has_b == 1) { g_line_range_end = b; }
    else            { g_line_range_end = 0; }
    if (g_line_range_start > 0) {
        if (g_line_range_end > 0) {
            if (g_line_range_start > g_line_range_end) { return 1; }
        }
    }
    return 0;
}

# --strip-ansi=auto|always|never. less -R naming for the existing -r
# behavior plus an "always" mode that strips even in plain output.
fn set_strip_ansi(value) {
    if (streq(value, "auto") == 1)   { g_flag_strip_ansi = 0; return 0; }
    if (streq(value, "always") == 1) { g_flag_strip_ansi = 1; return 0; }
    if (streq(value, "never") == 1)  { g_flag_strip_ansi = 2; return 0; }
    return 1;
}

# Parse --tabs=N. Rejects negative values. Returns 0 OK, 1 on error.
fn set_tabs(value) {
    var vlen = strlen(value);
    if (vlen == 0) { return 1; }
    var p = 0;
    while (p < vlen) {
        var c = load8(value + p);
        if (c < 48) { return 1; }
        if (c > 57) { return 1; }
        p = p + 1;
    }
    g_flag_tabs = atoi(value);
    return 0;
}

# Pager gate — uses is_tty (local) and g_flag_plain (local); reads
# g_flag_paging from pager.cyr. Kept here so pager.cyr stays
# dependency-free of main.
fn should_page() {
    if (g_flag_plain == 1) { return 0; }
    if (g_flag_paging == 0) { return 0; }
    if (is_tty(STDOUT) == 0) { return 0; }
    return 1;
}

fn main() {
    alloc_init();
    args_init();
    # Config → env → CLI: read the file first so CLI flags parsed
    # below always win. Missing file is a silent no-op.
    config_load();

    var n = argc();
    var ok = 0;
    var fail = 0;
    var any_positional = 0;

    var i = 1;
    while (i < n) {
        var a = argv(i);

        if (streq(a, "-V") == 1) {
            var k = i + 1;
            while (k < n) {
                var ak = argv(k);
                if (streq(ak, "--verbose") == 1) { g_flag_verbose = 1; }
                if (streq(ak, "-v") == 1)        { g_flag_verbose = 1; }
                k = k + 1;
            }
            return print_version();
        }
        if (streq(a, "--version") == 1) {
            var k = i + 1;
            while (k < n) {
                var ak = argv(k);
                if (streq(ak, "--verbose") == 1) { g_flag_verbose = 1; }
                if (streq(ak, "-v") == 1)        { g_flag_verbose = 1; }
                k = k + 1;
            }
            return print_version();
        }
        if (streq(a, "-h") == 1)        { return print_help(); }
        if (streq(a, "--help") == 1)    { return print_help(); }

        if (streq(a, "--list-themes") == 1)    { return print_theme_list(); }
        if (streq(a, "--list-languages") == 1) { return print_language_list(); }

        if (streq(a, "-n") == 1)         { g_flag_numbers = 1; i = i + 1; continue; }
        if (streq(a, "--number") == 1)   { g_flag_numbers = 1; i = i + 1; continue; }
        if (streq(a, "-N") == 1)         { g_flag_numbers = 0; i = i + 1; continue; }
        if (streq(a, "--no-number") == 1) { g_flag_numbers = 0; i = i + 1; continue; }
        if (streq(a, "-p") == 1)         { g_flag_plain = 1; i = i + 1; continue; }
        if (streq(a, "--plain") == 1)    { g_flag_plain = 1; i = i + 1; continue; }
        if (streq(a, "-A") == 1)         { g_flag_show_all = 1; i = i + 1; continue; }
        if (streq(a, "--show-all") == 1) { g_flag_show_all = 1; i = i + 1; continue; }
        if (streq(a, "-v") == 1)         { g_flag_verbose = 1; i = i + 1; continue; }
        if (streq(a, "--verbose") == 1)  { g_flag_verbose = 1; i = i + 1; continue; }
        if (streq(a, "-x") == 1)         { g_flag_hex = 1; i = i + 1; continue; }
        if (streq(a, "--hex") == 1)      { g_flag_hex = 1; i = i + 1; continue; }
        if (streq(a, "--diff") == 1)     { g_flag_diff = 1; i = i + 1; continue; }
        if (streq(a, "-r") == 1)                     { g_flag_raw_controls = 1; i = i + 1; continue; }
        if (streq(a, "--raw-control-chars") == 1)    { g_flag_raw_controls = 1; i = i + 1; continue; }

        var v = match_eq_flag(a, "--color");
        if (v != 0) {
            if (set_color(v) != 0) {
                report_error(a, "invalid value (want auto|always|never)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--paging");
        if (v != 0) {
            if (set_paging(v) != 0) {
                report_error(a, "invalid value (want auto|always|never)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--style");
        if (v != 0) {
            if (set_style(v) != 0) {
                report_error(a, "invalid value (want auto|changes|no-changes)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--theme");
        if (v != 0) {
            var tidx = theme_index(v);
            if (tidx < 0) {
                report_error(a, "unknown theme (try --list-themes)");
                return EXIT_USAGE;
            }
            g_active_theme = tidx;
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--language");
        if (v != 0) {
            if (lang_is_valid(v) == 0) {
                report_error(a, "unknown language (try --list-languages)");
                return EXIT_USAGE;
            }
            g_flag_lang = v;
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--tabs");
        if (v != 0) {
            if (set_tabs(v) != 0) {
                report_error(a, "invalid value (want a non-negative integer)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--wrap");
        if (v != 0) {
            if (set_wrap(v) != 0) {
                report_error(a, "invalid value (want auto|never|character)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--strip-ansi");
        if (v != 0) {
            if (set_strip_ansi(v) != 0) {
                report_error(a, "invalid value (want auto|always|never)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }
        v = match_eq_flag(a, "--line-range");
        if (v != 0) {
            if (set_line_range(v) != 0) {
                report_error(a, "invalid value (want A:B, A:, :B, or A)");
                return EXIT_USAGE;
            }
            i = i + 1;
            continue;
        }

        if (streq(a, "-") == 1) {
            if (any_positional == 0) { resolve_mode(); if (should_page() == 1) { start_pager(); } }
            any_positional = 1;
            var stdin_rc = render_fd(STDIN, "<stdin>");
            emit_footer();
            if (stdin_rc < 0) { fail = fail + 1; } else { ok = ok + 1; }
            i = i + 1;
            continue;
        }

        if (load8(a) == 45) {
            report_error(a, "unknown option");
            return EXIT_USAGE;
        }

        if (any_positional == 0) { resolve_mode(); if (should_page() == 1) { start_pager(); } }
        any_positional = 1;
        var file_rc = render_path(a);
        emit_footer();
        if (file_rc < 0) { fail = fail + 1; } else { ok = ok + 1; }
        i = i + 1;
    }

    if (any_positional == 0) {
        if (is_tty(STDIN) == 1) { return print_help(); }
        resolve_mode();
        if (should_page() == 1) { start_pager(); }
        var bare_rc = render_fd(STDIN, "<stdin>");
        emit_footer();
        stop_pager();
        if (bare_rc < 0) { return EXIT_ALL_FAIL; }
        return EXIT_OK;
    }

    var exit_code = EXIT_OK;
    if (ok == 0) { if (fail > 0) { exit_code = EXIT_ALL_FAIL; } }
    if (exit_code == EXIT_OK) {
        if (fail > 0) { exit_code = EXIT_PARTIAL; }
    }
    stop_pager();
    return exit_code;
}

var r = main();
syscall(SYS_EXIT, r);

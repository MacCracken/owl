# Build + dist
/build/
/dist/
/out/
/pkg/

# Cyrius vendored deps — regenerated by `cyrius deps`
# (k*-prefixed entries are preserved for kernel consumers; doesn't apply
# to owl today but matches agnosticos convention)
lib/*.cyr
!lib/k*.cyr

# Release / toolchain artifacts
cyrius-*.tar.gz
*.tar.gz
SHA256SUMS
SHA256SUMS.*

# Local runtime
*.core
.claude/

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Secrets (never commit)
.env
.env.*
*.pem
*.key
